# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/
env/

# Environment / secrets
.env

# Data — raw downloads and intermediate artifacts are not committed.
# Exception: small hard-coded fixture JSON/CSV for the 2026 tournament.
data/raw/*
!data/raw/.gitkeep
!data/raw/wc2026_groups.json
!data/raw/wc2026_fixtures.csv
!data/raw/wc2026_bracket_map.json
!data/raw/confederations.json
data/interim/*
!data/interim/.gitkeep
data/processed/*
!data/processed/.gitkeep

# Serialized models
models/*
!models/.gitkeep

# Notebooks scratch
.ipynb_checkpoints/

# OS
.DS_Store

# Stray R history
.Rhistory
