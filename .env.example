# Copy to `.env` and adjust as needed. The .env file is gitignored.
# v1 needs no secrets; these are optional overrides.

# Override the project data directory (defaults to ./data).
# WC2026_DATA_DIR=/absolute/path/to/data

# Override the models directory (defaults to ./models).
# WC2026_MODELS_DIR=/absolute/path/to/models

# Logging verbosity for the package (DEBUG, INFO, WARNING, ERROR).
# WC2026_LOG_LEVEL=INFO
